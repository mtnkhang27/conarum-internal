{
  "name": "cnma_internal_prediction",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@types/jest": "^30.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "@cap-js/cds-types": "^0.15.0",
    "@types/node": "^24.0.0",
    "tsx": "^4",
    "typescript": "^5",
    "@cap-js/cds-typer": ">=0.1"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build:cf": "npm run build:cds && npm run cleanup:ts && npm run build:ts",
    "build:ts": "tsc",
    "build:cds": "cds build --production",
    "cleanup:ts": "npx rimraf --glob \"gen/srv/srv/**/*.ts\"",
    "lint-service": "eslint srv",
    "lint-ui": "eslint app/internal-sport/src",
    "ts-typecheck": "tsc --noEmit",
    "undeploy": "cf undeploy cnma_internal_prediction --delete-services --delete-service-keys",
    "clean": "npx rimraf gen mta_archives cnma_internal_prediction.mtar app.zip ui_resources .cnma_internal_prediction_mta_build_tmp @cds-models srv-compiled",
    "build": "cds build --production",
    "build:db": "cds build --production",
    "deploy": "cds build --production && mbt build && cf deploy mta_archives/cnma_internal_prediction_1.0.0.mtar --retries 1",
    "deploy:db": "npm run build:db && cds deploy --to hana",
    "build:srv": "rimraf resources mta_archives && mbt module-build -m=cnma_internal_prediction_srv -a -g -t mta_archives",
    "deploy:srv": "npm run build:srv && cf deploy cnma_internal_prediction.mtar -m=cnma_internal_prediction_srv",
    "build:app": "npm run build:rls",
    "deploy:app": "npm run build:app && cf deploy mta_archives/cnma_internal_prediction_1.0.0.mtar -m cnma_internal_prediction_ui_deployer",
    "build:rls": "npm run clean && npm run build && mbt build --mtar cnma_internal_prediction_1.0.0.mtar",
    "deploy:cf": "cf deploy mta_archives/cnma_internal_prediction_1.0.0.mtar --retries 1",
    "deploy:full": "npm run build:rls && npm run deploy:cf",
    "cf:payg": "cf login -a https://api.cf.eu10.hana.ondemand.com",
    "cf:cpea": "cf login -a https://api.cf.eu10-004.hana.ondemand.com",
    "cf:dev": "cf target -o proconarum-development-system",
    "cf:qas": "cf target -o proconarum-quality-system",
    "cf:logs": "cf logs cnma_internal_prediction_srv",
    "start:hybrid:backend": "cds watch --profile hybrid",
    "start:hybrid:frontend": "npm run dev --prefix app/internal-sport"
  },
  "private": true,
  "cds": {
    "build": {
      "typescript": true
    },
    "server": {
      "body_parser": {
        "limit": "20mb"
      }
    },
    "requires": {
      "auth": {
        "strategy": "xsuaa",
        "[development]": {
          "strategy": "dummy",
          "users": {
            "admin": {
              "password": "admin",
              "roles": [
                "PredictionAdmin",
                "PredictionUser",
                "admin",
                "authenticated-user"
              ],
              "attr": {
                "name": "Admin User"
              }
            },
            "nguyen.a@conarum.com": {
              "password": "player",
              "roles": [
                "PredictionUser",
                "authenticated-user"
              ],
              "attr": {
                "name": "Nguyen Van A"
              }
            },
            "tran.b@conarum.com": {
              "password": "player",
              "roles": [
                "PredictionUser",
                "authenticated-user"
              ],
              "attr": {
                "name": "Tran Thi B"
              }
            },
            "nam.vu@conarum.com": {
              "password": "admin",
              "roles": [
                "PredictionAdmin",
                "PredictionUser",
                "admin",
                "authenticated-user"
              ],
              "attr": {
                "name": "Nam Vu"
              }
            }
          }
        }
      },
      "db": {
        "kind": "hana",
        "pool": {
          "max": 20,
          "acquireTimeoutMillis": 60000,
          "idleTimeoutMillis": 30000,
          "communicationTimeout": 600000
        }
      }
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}